{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tou-analyzer",
  "main": "./src/worker.ts",
  "preview_urls": true,
  "compatibility_date": "2026-05-12",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
