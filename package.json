{
  "name": "tou-analyzer",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "description": "Static, local-only Utah Schedule 1 time-of-use analyzer.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "generate-favicons": "node scripts/generate-favicons.mjs",
    "build": "npm run generate-favicons && tsc --noEmit && vite build",
    "deploy": "npm run build && npx wrangler deploy",
    "deploy:preview": "npm run build && npx wrangler versions upload",
    "test": "vitest run",
    "test:e2e": "playwright test --project=chromium --grep-invert @performance",
    "test:e2e:ui": "playwright test --ui",
    "test:perf": "playwright test --project=chromium --grep @performance",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@uwdata/vgplot": "^0.18.0",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "wrangler": "^4.92.0"
  }
}
